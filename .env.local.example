# ────────────────────────────────────────────────────────────────────
# Supabase — copy these from your project's Settings → API page.
# In local dev, run `pnpm exec supabase status` to get them.
# ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────────────────────────
# Host / URLs
#   ROOT_DOMAIN      → where the app is served. Used by the middleware
#                      to decide between subdomain (prod) and path (dev).
#   NEXT_PUBLIC_SITE_URL → full public URL (with https:// in prod).
#                      Used for Mercado Pago back_urls, webhook, OAuth.
#
# Dev:
#   ROOT_DOMAIN=localhost:3000
#   NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Prod:
#   ROOT_DOMAIN=pedidos.com.ar
#   NEXT_PUBLIC_SITE_URL=https://pedidos.com.ar
# ────────────────────────────────────────────────────────────────────
ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────
# Upstash Redis — OPTIONAL. Enables rate limiting on createOrder and on
# WhatsApp verification-code sends (spec 25).
# Without these, rate limiting silently passes through.
# Create a free DB at https://upstash.com and grab the REST creds.
# ────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────────────
# Phone verification by WhatsApp (spec 25)
#   PHONE_VERIFICATION_PEPPER         → server-only secret mixed into the
#                                       code hash. Set a long random string.
#   PHONE_VERIFICATION_TEMPLATE_NAME  → Meta-approved "authentication"
#                                       template name (default: verificacion_cuenta)
#   PHONE_VERIFICATION_TEMPLATE_LANG  → template language (default: es_AR)
# The WhatsApp 360dialog credentials are per-business (whatsapp_credentials
# table), not env. If a business has none, verification is skipped gracefully.
# ────────────────────────────────────────────────────────────────────
PHONE_VERIFICATION_PEPPER=
PHONE_VERIFICATION_TEMPLATE_NAME=
PHONE_VERIFICATION_TEMPLATE_LANG=

# ────────────────────────────────────────────────────────────────────
# Google OAuth — these DON'T go here. They go in the Supabase
# dashboard: Authentication → Providers → Google.
#
#   Client ID:     from Google Cloud Console → OAuth 2.0 Client
#   Client Secret: same
#   Redirect URI (to add to Google):
#     Local:  http://127.0.0.1:54321/auth/v1/callback
#     Prod:   https://xxxx.supabase.co/auth/v1/callback
# ────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────
# Mercado Pago — per-business, stored in the `businesses` table via
# the admin Config screen. No env vars needed for MP.
# ────────────────────────────────────────────────────────────────────
